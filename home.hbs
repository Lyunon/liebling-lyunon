{{!< default}}

{{#contentFor "styles"}}
  <link rel="stylesheet" type="text/css" href="{{asset "css/custom-home.css"}}" media="screen" />
{{/contentFor}}

{{> header}}

<main class="main-wrap">

  <!-- HERO -->
  <section class="ly-hero">
    <div class="l-wrapper">
      <div class="ly-hero__grid">
        <div class="ly-hero__text" data-animate="fade-down">
          <p class="ly-hero__kicker">Chzzk Virtual Streamer</p>
          <h1 class="ly-hero__title">륜온</h1>
          <p class="ly-hero__desc">
            버츄얼 스트리머 륜온의 블로그입니다.<br>
            방송 후기나 아카이빙, 커미션 공지 등의 목적으로 사용하는 공간입니다.
          </p>

          <div class="ly-hero__actions">
            <a href="/lyunon_tarot/" class="m-button filled">타로 신청</a>
            <a href="/tag/broadcast/" class="m-button filled">방송 후기</a>
            <a href="/profile/" class="m-button filled">소개 보기</a>
          </div>
        </div>

        <div class="ly-hero__visual" data-animate="fade-up">
          <img src="{{asset "images/lyunon.png"}}" alt="륜온 캐릭터 반신 이미지">
        </div>
      </div>
    </div>
  </section>

  <section class="ly-section ly-section--notice-banner">
    <div class="l-wrapper">
      {{#get "posts" filter="tag:home-notice" limit="1" order="published_at desc" include="tags,authors"}}
        {{#if posts}}
          {{#foreach posts}}
            <a class="ly-notice-banner" href="{{url}}">
              <div class="ly-notice-banner__label">NOTICE</div>
              <div class="ly-notice-banner__body">
                <h2 class="ly-notice-banner__title">{{title}}</h2>
                {{#if custom_excerpt}}
                  <p class="ly-notice-banner__desc">{{custom_excerpt}}</p>
                {{else}}
                  <p class="ly-notice-banner__desc">{{excerpt words="18"}}</p>
                {{/if}}
              </div>
              <div class="ly-notice-banner__meta">
                <span>{{date published_at format="YYYY.MM.DD"}}</span>
                <span>·</span>
                <span>{{reading_time}}</span>
              </div>
            </a>
          {{/foreach}}
        {{/if}}
      {{/get}}
    </div>
  </section>

  <!-- FEATURED -->
  <section class="ly-section ly-section--featured">
    <div class="l-wrapper">

      {{#get "posts" filter="tag:featured-home" limit="1" include="tags,authors"}}
        {{#if posts}}

          {{#foreach posts}}
            {{> "featured-card"}}
          {{/foreach}}

        {{else}}

          {{#get "posts" limit="2" include="tags,authors"}}
            {{#foreach posts}}
              {{> "featured-card"}}
            {{/foreach}}
          {{/get}}

        {{/if}}
      {{/get}}

    </div>
  </section>

  <!-- POSTS -->
  <section class="ly-section">
    <div class="l-wrapper">
      <div class="ly-section__head">
        <h2>Latest Arcana</h2>
        <p>최신 글을 한눈에 확인해 보세요.</p>
      </div>

      {{#get "posts" include="tags,authors" limit="6"}}
        {{#if posts}}
          <div class="ly-post-grid">
            {{#foreach posts}}
              <article class="ly-post-card {{#if primary_tag}}ly-post-card--{{primary_tag.slug}}{{/if}}">
                <a class="ly-post-card__media" href="{{url}}">
                  {{#if feature_image}}
                    <img src="{{img_url feature_image size="m"}}" alt="{{title}}">
                  {{else}}
                    <img src="{{asset "images/default-thumb.png"}}" alt="기본 썸네일">
                  {{/if}}
                </a>

                <div class="ly-post-card__content">
                  {{#if primary_tag}}
                    <span class="ly-post-card__tag">{{primary_tag.name}}</span>
                  {{/if}}

                  <h3 class="ly-post-card__title">
                    <a href="{{url}}">{{title}}</a>
                  </h3>

                  <div class="ly-post-card__meta">
                    <span>{{date published_at format="YYYY.MM.DD"}}</span>
                    <span>·</span>
                    <span>{{reading_time}}</span>
                  </div>
                </div>
              </article>
            {{/foreach}}
          </div>
        {{else}}
          <p>아직 게시물이 없습니다.</p>
        {{/if}}
      {{/get}}
    </div>
  </section>

  <!-- TAGS -->
  <section class="ly-section ly-section--tags">
    <div class="l-wrapper">
      <div class="ly-section__head">
        <h2>Oracle Links</h2>
        <p>자주 가는 공간으로 바로 이동할 수 있어요.</p>
      </div>

      <div class="ly-tag-grid">
        <a class="ly-tag-card" href="/tag/tarot/">
          <strong>🔮 Tarot</strong>
          <span>타로 관련</span>
        </a>

        <a class="ly-tag-card" href="/tag/broadcast/">
          <strong>🎥 Broadcast</strong>
          <span>방송 관련</span>
        </a>

        <a class="ly-tag-card" href="/tag/notice/">
          <strong>📜 Notice</strong>
          <span>공지</span>
        </a>

        <a class="ly-tag-card" href="https://chzzk.naver.com/b588ed6529498d3ba9600fd99c9455c1" target="_blank" rel="noopener">
          <strong>⚡ Chzzk</strong>
          <span>치지직 채널 이동</span>
        </a>
      </div>
    </div>
  </section>
</main>
