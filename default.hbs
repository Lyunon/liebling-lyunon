<!DOCTYPE html>
<html lang="{{@site.locale}}">
  <head>
    {{!-- Document Settings --}}
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    {{!-- Base Meta --}}
    <title>{{meta_title}}</title>
    <meta name="HandheldFriendly" content="True" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {{!-- Preload assets --}}
    <link rel="preload" href="{{asset "css/app.css"}}" as="style" />
    <link rel="preload" href="{{asset "js/manifest.js"}}" as="script" />
    <link rel="preload" href="{{asset "js/vendor.js"}}" as="script" />
    <link rel="preload" href="{{asset "js/app.js"}}" as="script" />
    <link rel="stylesheet" href="{{asset "css/custom-content.css"}}" />

    {{!-- This #block helper will try to preload page-specific assets --}}
    {{{block "preload"}}}

    {{!-- Styles & Scripts --}}
    <style>
      /* These font-faces are here to make fonts work if the Ghost instance is installed in a subdirectory */

      /* source-sans-pro-regular */
      @font-face {
        font-family: 'Source Sans Pro';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: local('SourceSansPro-Regular'),
            url("{{asset 'fonts/source-sans-pro/latin/source-sans-pro-regular.woff2'}}") format('woff2'),
            url("{{asset 'fonts/source-sans-pro/latin/source-sans-pro-regular.woff'}}") format('woff');
      }

      /* source-sans-pro-600 */
      @font-face {
        font-family: 'Source Sans Pro';
        font-style: normal;
        font-weight: 600;
        font-display: swap;
        src: local('SourceSansPro-SemiBold'),
            url("{{asset 'fonts/source-sans-pro/latin/source-sans-pro-600.woff2'}}") format('woff2'),
            url("{{asset 'fonts/source-sans-pro/latin/source-sans-pro-600.woff'}}") format('woff');
      }

      /* source-sans-pro-700 */
      @font-face {
        font-family: 'Source Sans Pro';
        font-style: normal;
        font-weight: 700;
        font-display: swap;
        src: local('SourceSansPro-Bold'),
            url("{{asset 'fonts/source-sans-pro/latin/source-sans-pro-700.woff2'}}") format('woff2'),
            url("{{asset 'fonts/source-sans-pro/latin/source-sans-pro-700.woff'}}") format('woff');
      }

      /* iconmoon */
      @font-face {
        font-family: 'icomoon';
        font-weight: normal;
        font-style: normal;
        font-display: swap;
        src: url("{{asset 'fonts/icomoon/icomoon.eot?101fc3'}}");
        src: url("{{asset 'fonts/icomoon/icomoon.eot?101fc3#iefix'}}") format('embedded-opentype'),
        url("{{asset 'fonts/icomoon/icomoon.ttf?101fc3'}}") format('truetype'),
        url("{{asset 'fonts/icomoon/icomoon.woff?101fc3'}}") format('woff'),
        url("{{asset 'fonts/icomoon/icomoon.svg?101fc3#icomoon'}}") format('svg');
      }
    </style>

    <link rel="stylesheet" type="text/css" href="{{asset "css/app.css"}}" media="screen" />
    <link rel="stylesheet" type="text/css" href="{{asset "css/season-effects.css"}}" media="screen" />

    {{!-- This #block helper will inject a stylesheet for a specific page --}}
    {{{block "styles"}}}

    {{!-- This #block helper will pull data from the hero partial
    to inject styles of the hero image to make it responsive --}}
    {{{block "herobackground"}}}

    {{!-- This tag outputs SEO meta+structured data and other important settings --}}
    {{ghost_head}}

    {{!-- This style overrides the accent color to match the one from the Admin --}}
    <style>
      :root {
        --primary-subtle-color: var(--ghost-accent-color) !important;
      }
    </style>

    {{!-- These variables are used to make the search form work --}}
    <script>
      // @license magnet:?xt=urn:btih:d3d9a9a6595521f9666a5e94cc830dab83b65699&dn=expat.txt Expat
      const ghostHost = "{{@site.url}}"
      // @license-end
    </script>

    {{#if @custom.enable_native_search}}
      <script>
        const nativeSearchEnabled = true
      </script>
    {{/if}}

    {{#if @custom.search_api_key}}
      <script>
        const ghostSearchApiKey = "{{@custom.search_api_key}}"
      </script>
    {{/if}}

    {{!-- This variable disbale the fade animation when it's enabled --}}
    {{#if @custom.disable_fade_animation}}
      <style>
        :root {
          --show-fade-animation: 0;
        }
      </style>
    {{/if}}

    {{!-- This script sets the correct theme mode (light or dark) --}}
    <script>
      if (typeof Storage !== 'undefined') {
        const currentSavedTheme = localStorage.getItem('theme')

        if (currentSavedTheme && currentSavedTheme === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark')
        } else {
          document.documentElement.setAttribute('data-theme', 'light')
        }
      }
    </script>
  </head>
  <body class="{{body_class}}">
    {{!-- All the main content gets inserted here, index.hbs, post.hbs, etc --}}
    {{{body}}}

    <canvas id="season-canvas"></canvas>
    <div class="season-overlay" aria-hidden="true"></div>

    {{!-- Search form --}}
    {{^if @custom.enable_native_search}}
      {{> search}}
    {{/if}}

    {{!-- The footer --}}
    {{> footer}}

    {{!-- Common scripts shared between pages --}}
    <script defer src="{{asset "js/manifest.js"}}"></script>
    <script defer src="{{asset "js/vendor.js"}}"></script>
    <script defer src="{{asset "js/app.js"}}"></script>

    {{!-- The #block helper will pull in data from the #contentFor other template files --}}
    {{{block "scripts"}}}

    {{!-- Ghost outputs important scripts and data with this tag --}}
    <script>
      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const cards = document.querySelectorAll('.ly-post-card');
            cards.forEach((card, i) => {
              setTimeout(() => {
                card.classList.add('is-visible');
              }, i * 60);
            });
            observer.disconnect();
          }
        });
      });

      const firstCard = document.querySelector('.ly-post-card');
      if (firstCard) {
        observer.observe(firstCard);
      }
    </script>
    
    <script>
      document.querySelectorAll('.ly-post-card').forEach(card => {
        card.addEventListener('mousemove', e => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;

          const centerX = rect.width / 2;
          const centerY = rect.height / 2;

          const rotateY = ((x - centerX) / centerX) * 5;
          const rotateX = ((centerY - y) / centerY) * 5;

          card.style.setProperty('--x', `${x}px`);
          card.style.setProperty('--y', `${y}px`);
          card.style.setProperty('--rotateX', `${rotateX}deg`);
          card.style.setProperty('--rotateY', `${rotateY}deg`);
        });

        card.addEventListener('mouseleave', () => {
          card.style.removeProperty('--x');
          card.style.removeProperty('--y');
          card.style.setProperty('--rotateX', '0deg');
          card.style.setProperty('--rotateY', '0deg');
        });

        card.addEventListener('click', e => {
          const rect = card.getBoundingClientRect();
          const ripple = document.createElement('span');

          ripple.className = 'ly-post-card__ripple';
          ripple.style.left = `${e.clientX - rect.left}px`;
          ripple.style.top = `${e.clientY - rect.top}px`;

          card.appendChild(ripple);

          ripple.addEventListener('animationend', () => {
            ripple.remove();
          });
        });

        card.addEventListener('click', () => {
          card.classList.add('is-clicked');
          setTimeout(() => card.classList.remove('is-clicked'), 220);
        });
      });
    </script>

    <script>
    
    document.addEventListener('DOMContentLoaded', () => {
      const canvas = document.getElementById('season-canvas');
      if (!canvas) return;
    
      const ctx = canvas.getContext('2d');
      let particles = [];
      let ripples = [];
      let snowAccum = [];
      let type = 'snow';
    
      const forced = localStorage.getItem('force-season');
      const month = new Date().getMonth() + 1;
    
      if (forced) {
        type = forced;
      } else {
        if (month >= 3 && month <= 5) type = 'sakura';
        else if (month >= 6 && month <= 8) type = 'rain';
        else if (month >= 9 && month <= 11) type = 'leaf';
        else type = 'snow';
      }
    
      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }
    
      window.addEventListener('resize', resize);
      resize();
    
      function randomBetween(min, max) {
        return Math.random() * (max - min) + min;
      }
    
      function createParticle() {
        if (type === 'rain') {
          return {
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            len: randomBetween(12, 18),
            speedY: randomBetween(5.2, 7.8),
            speedX: randomBetween(-0.2, 0.2),
            alpha: randomBetween(0.3, 0.55),
            color: '180,220,255'
          };
        }
    
        if (type === 'snow') {
          const layer = Math.random();
        
          if (layer < 0.55) {
            // 작은 눈
            return {
              x: Math.random() * canvas.width,
              y: Math.random() * canvas.height,
              size: randomBetween(1.8, 3.2),
              speedY: randomBetween(0.18, 0.45),
              speedX: randomBetween(-0.22, 0.22),
              drift: randomBetween(0.004, 0.012),
              wobble: Math.random() * Math.PI * 2,
              alpha: randomBetween(0.45, 0.8),
              color: '255,255,255',
              rotation: 0,
              rotationSpeed: randomBetween(-0.006, 0.006),
              twinkle: randomBetween(0.002, 0.008),
              twinklePhase: Math.random() * Math.PI * 2
            };
          }
        
          if (layer < 0.88) {
            // 중간 눈
            return {
              x: Math.random() * canvas.width,
              y: Math.random() * canvas.height,
              size: randomBetween(3.2, 5.4),
              speedY: randomBetween(0.28, 0.72),
              speedX: randomBetween(-0.3, 0.3),
              drift: randomBetween(0.006, 0.018),
              wobble: Math.random() * Math.PI * 2,
              alpha: randomBetween(0.58, 0.92),
              color: '245,250,255',
              rotation: 0,
              rotationSpeed: randomBetween(-0.01, 0.01),
              twinkle: randomBetween(0.004, 0.012),
              twinklePhase: Math.random() * Math.PI * 2
            };
          }
        
          // 큰 눈
          return {
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            size: randomBetween(5.4, 7.8),
            speedY: randomBetween(0.2, 0.52),
            speedX: randomBetween(-0.4, 0.4),
            drift: randomBetween(0.008, 0.02),
            wobble: Math.random() * Math.PI * 2,
            alpha: randomBetween(0.45, 0.78),
            color: '230,240,255',
            rotation: 0,
            rotationSpeed: randomBetween(-0.012, 0.012),
            twinkle: randomBetween(0.003, 0.01),
            twinklePhase: Math.random() * Math.PI * 2
          };
        }
    
        if (type === 'sakura') {
          return {
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            size: randomBetween(8, 14),
            speedY: randomBetween(0.22, 0.55),
            speedX: randomBetween(-0.45, 0.45),
            drift: randomBetween(0.01, 0.025),
            wobble: Math.random() * Math.PI * 2,
            alpha: randomBetween(0.65, 0.95),
            color: Math.random() > 0.5 ? '255,190,220' : '255,215,235',
            rotation: Math.random() * Math.PI * 2,
            rotationSpeed: randomBetween(-0.02, 0.02)
          };
        }
    
        return {
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          size: randomBetween(11, 17),
          speedY: randomBetween(0.26, 0.58),
          speedX: randomBetween(-0.45, 0.45),
          drift: randomBetween(0.01, 0.02),
          wobble: Math.random() * Math.PI * 2,
          alpha: randomBetween(0.72, 0.96),
          color: Math.random() > 0.5 ? '235,125,45' : '210,80,30',
          rotation: Math.random() * Math.PI * 2,
          rotationSpeed: randomBetween(-0.014, 0.014)
        };
      }
    
      function init() {
        const count =
          type === 'rain' ? 95 :
          type === 'snow' ? 95 :
          type === 'sakura' ? 42 :
          34;
    
        particles = [];
        ripples = [];

        if (type === 'snow') {
          snowAccum = new Array(canvas.width).fill(0);
        }
    
        for (let i = 0; i < count; i++) {
          particles.push(createParticle());
        }
      }
    
      function drawRain(p) {
        ctx.beginPath();
        ctx.strokeStyle = `rgba(${p.color}, ${p.alpha})`;
        ctx.lineWidth = 1.2;
        ctx.moveTo(p.x, p.y);
        ctx.lineTo(p.x + p.speedX * 5, p.y + p.len);
        ctx.stroke();
      }
    
      function drawSnow(p) {
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rotation);
      
        const pulse = 0.88 + Math.sin(p.twinklePhase) * 0.12;
        const alpha = Math.max(0.18, p.alpha * pulse);
      
        // 바깥 흐림
        ctx.beginPath();
        ctx.fillStyle = `rgba(${p.color}, ${alpha * 0.18})`;
        ctx.arc(0, 0, p.size * 0.9, 0, Math.PI * 2);
        ctx.fill();
      
        // 본체
        ctx.beginPath();
        ctx.fillStyle = `rgba(${p.color}, ${alpha})`;
        ctx.arc(0, 0, p.size / 2, 0, Math.PI * 2);
        ctx.fill();
      
        // 중심 하이라이트
        ctx.beginPath();
        ctx.fillStyle = `rgba(255,255,255, ${Math.min(alpha, 0.95)})`;
        ctx.arc(-p.size * 0.08, -p.size * 0.08, p.size / 5.5, 0, Math.PI * 2);
        ctx.fill();
      
        ctx.restore();
      }
    
      function drawSakura(p) {
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rotation);
        ctx.scale(1, 0.92);
    
        ctx.fillStyle = `rgba(${p.color}, ${p.alpha})`;
        const s = p.size / 2.4;
    
        for (let i = 0; i < 4; i++) {
          ctx.save();
          ctx.rotate((Math.PI / 2) * i);
          ctx.beginPath();
          ctx.moveTo(0, 0);
          ctx.bezierCurveTo(s * 0.4, -s * 1.2, s * 1.2, -s * 1.1, 0, -s * 2);
          ctx.bezierCurveTo(-s * 1.2, -s * 1.1, -s * 0.4, -s * 1.2, 0, 0);
          ctx.fill();
          ctx.restore();
        }
    
        ctx.fillStyle = `rgba(255, 245, 250, ${Math.min(p.alpha, 0.9)})`;
        ctx.beginPath();
        ctx.arc(0, 0, s * 0.38, 0, Math.PI * 2);
        ctx.fill();
    
        ctx.restore();
      }
    
      function drawMapleLeaf(p) {
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rotation);
    
        const s = p.size;
        ctx.fillStyle = `rgba(${p.color}, ${p.alpha})`;
    
        // 5갈래 작은 단풍 실루엣
        ctx.beginPath();
        ctx.moveTo(0, -s * 1.1);
    
        ctx.lineTo(s * 0.18, -s * 0.55);
        ctx.lineTo(s * 0.62, -s * 0.82);
        ctx.lineTo(s * 0.42, -s * 0.28);
        ctx.lineTo(s * 0.95, -s * 0.08);
        ctx.lineTo(s * 0.34, s * 0.12);
        ctx.lineTo(s * 0.55, s * 0.72);
        ctx.lineTo(s * 0.08, s * 0.34);
        ctx.lineTo(0, s * 1.12);
        ctx.lineTo(-s * 0.08, s * 0.34);
        ctx.lineTo(-s * 0.55, s * 0.72);
        ctx.lineTo(-s * 0.34, s * 0.12);
        ctx.lineTo(-s * 0.95, -s * 0.08);
        ctx.lineTo(-s * 0.42, -s * 0.28);
        ctx.lineTo(-s * 0.62, -s * 0.82);
        ctx.lineTo(-s * 0.18, -s * 0.55);
        ctx.closePath();
        ctx.fill();
    
        // 중앙 줄기
        ctx.strokeStyle = `rgba(110, 50, 15, ${p.alpha * 0.7})`;
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(0, -s * 0.85);
        ctx.lineTo(0, s * 1.02);
        ctx.stroke();
    
        ctx.restore();
      }
    
      function drawParticle(p) {
        if (type === 'rain') return drawRain(p);
        if (type === 'snow') return drawSnow(p);
        if (type === 'sakura') return drawSakura(p);
        if (type === 'leaf') return drawMapleLeaf(p);
      }
    
      function addRipple(x) {
        ripples.push({
          x,
          y: canvas.height - 26,
          radius: 2,
          alpha: 0.18,
          grow: randomBetween(0.45, 0.75)
        });
      }
    
      function updateRipples() {
        ctx.save();
        for (let i = ripples.length - 1; i >= 0; i--) {
          const r = ripples[i];
          r.radius += r.grow;
          r.alpha -= 0.0045;
    
          if (r.alpha <= 0) {
            ripples.splice(i, 1);
            continue;
          }
    
          ctx.beginPath();
          ctx.strokeStyle = `rgba(190, 225, 255, ${r.alpha})`;
          ctx.lineWidth = 1;
          ctx.ellipse(r.x, r.y, r.radius * 1.8, r.radius * 0.5, 0, 0, Math.PI * 2);
          ctx.stroke();
        }
        ctx.restore();
      }
    
      function updateParticle(p) {
        p.y += p.speedY;
      
        if (type === 'rain') {
          p.x += p.speedX;
      
          if (p.y > canvas.height - 30 && Math.random() < 0.08) {
            addRipple(p.x);
          }
        } else {
          p.wobble += p.drift;
          p.x += p.speedX + Math.sin(p.wobble) * 0.45;
          p.rotation += p.rotationSpeed;
      
          if (type === 'snow') {
            p.twinklePhase += p.twinkle;
      
            const ground = canvas.height - 8;
            if (p.y > ground) {
              const x = Math.floor(p.x);
      
              if (x >= 0 && x < snowAccum.length && snowAccum[x] < 12) {
                snowAccum[x] += p.size * 0.15;
              }
      
              p.y = -20;
              p.x = Math.random() * canvas.width;
              return;
            }
          }
        }
      
        if (p.y > canvas.height + 40) {
          Object.assign(p, createParticle(), {
            y: -40,
            x: Math.random() * canvas.width
          });
        }
      
        if (p.x < -50) p.x = canvas.width + 50;
        if (p.x > canvas.width + 50) p.x = -50;
      }

      function drawSnowAccum() {
        ctx.save();
      
        ctx.fillStyle = 'rgba(255,255,255,0.08)';
        ctx.beginPath();
        ctx.moveTo(0, canvas.height);
      
        for (let x = 0; x < canvas.width; x += 2) {
          const h = snowAccum[x] || 0;
          ctx.lineTo(x, canvas.height - h);
        }
      
        ctx.lineTo(canvas.width, canvas.height);
        ctx.closePath();
        ctx.fill();
      
        ctx.restore();
      }
    
      function loop() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
      
        for (const p of particles) {
          updateParticle(p);
          drawParticle(p);
        }
      
        if (type === 'snow') {
          drawSnowAccum();
        }
      
        if (type === 'rain') {
          updateRipples();
        }
      
        requestAnimationFrame(loop);
      }
    
      init();
      loop();
    });
    </script>

    {{ghost_foot}}
  </body>
</html>
